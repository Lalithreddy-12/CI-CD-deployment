pipeline {

    agent any

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/Lalithreddy-12/CI-CD-deployment.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Deploy') {
            steps {
                sshagent(credentials: ['tomcat-ssh-key']) {
                    sh '''
                    scp -o StrictHostKeyChecking=no \
                    target/jenkins-demo.war \
                    ubuntu@54.88.118.184:/home/ec2-user/apache/webapps/
                    '''
                }
            }
        }

    }

}