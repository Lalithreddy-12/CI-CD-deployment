pipeline {

    agent any

    stages {

        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Deploy') {
            steps {
                sshagent(credentials: ['tomcat-ssh-key']) {

                    sh '''
                    scp -o StrictHostKeyChecking=no \
                    target/jenkins-demo.war \
                    ec2-user@54.88.118.184:/home/ec2-user/apache/webapps/
                    '''

                }
            }
        }

    }
}